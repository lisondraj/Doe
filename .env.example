# Primary marketing domain for all pages except /join (default: doe.care)
PRIMARY_SITE_HOST=doe.care

# Dedicated join domain — /join is canonical here; other paths redirect to /join (default: doehealth.care)
JOIN_SITE_HOST=doehealth.care

# Absolute URL for "Join Waitlist" links (default: https://doehealth.care/join)
NEXT_PUBLIC_JOIN_URL=https://doehealth.care/join
