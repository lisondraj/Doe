# Supabase — Doe project (https://supabase.com/dashboard/project/tnferryxxngdoprlustj)
NEXT_PUBLIC_SUPABASE_URL=https://tnferryxxngdoprlustj.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Resend — sends applicant card copy on /join submit (https://resend.com)
# Vercel (recommended): Project → Settings → Environment Variables
#   RESEND_API_KEY=re_xxxxxxxxx   ← replace with your real key from Resend dashboard
#   RESEND_FROM_EMAIL=James <james@doe.care>   ← default if unset; any verified @doe.care address works
# Supabase Edge Functions only: add RESEND_API_KEY as a Supabase secret instead (not needed for current Next.js flow).
# Submissions still save when RESEND_API_KEY is missing; confirmation email is skipped.
RESEND_API_KEY=re_xxxxxxxxx
RESEND_FROM_EMAIL=James <james@doe.care>

# Primary marketing domain (default: doe.care)
PRIMARY_SITE_HOST=doe.care

# Designers landing domain — rewrites site root to /doehealth (default: doehealth.care)
DESIGNERS_SITE_HOST=doehealth.care

# Legacy alias for DESIGNERS_SITE_HOST
JOIN_SITE_HOST=doehealth.care

# Absolute URL for "Join Waitlist" links (default: https://doe.care/join)
NEXT_PUBLIC_JOIN_URL=https://doe.care/join
