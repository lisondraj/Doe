# Supabase — Doe project (https://supabase.com/dashboard/project/tnferryxxngdoprlustj)
NEXT_PUBLIC_SUPABASE_URL=https://tnferryxxngdoprlustj.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Resend — sends applicant card copy on submission (https://resend.com)
# Add both vars in Vercel → Project → Settings → Environment Variables for production.
# Submissions still save when these are missing; confirmation email is skipped.
RESEND_API_KEY=your-resend-api-key
RESEND_FROM_EMAIL=Doe <applications@doe.care>

# Primary marketing domain (default: doe.care)
PRIMARY_SITE_HOST=doe.care

# Legacy join domain — redirects to PRIMARY_SITE_HOST/join (default: doehealth.care)
JOIN_SITE_HOST=doehealth.care

# Absolute URL for "Join Waitlist" links (default: https://doe.care/join)
NEXT_PUBLIC_JOIN_URL=https://doe.care/join
